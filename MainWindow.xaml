<Window x:Class="WpfApp3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp3"
        mc:Ignorable="d"
        Title="MainWindow" Height="500" Width="350">
    <Window.Resources>
        <Style TargetType="Button" x:Key="MyStyle">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="DemiBold"/>
            <Setter Property="Width" Value="70"/>
            <Setter Property="Height" Value="60"/>
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource MyStyle}" x:Key="Opreater">
           
            <Setter Property="Background" Value="Black"></Setter>
            <Setter Property="Foreground" Value="White"></Setter>
        </Style>
        <Style TargetType="Button"  BasedOn="{StaticResource MyStyle}" x:Key="yellow">
           
            <Setter Property="Background" Value="Orange"></Setter>
            <Setter Property="Foreground" Value="White"></Setter>
        </Style>
        <Style TargetType="TextBlock" x:Key="AllTexts">
            <Setter Property="Margin" Value="15"></Setter>
            <Setter Property="HorizontalAlignment" Value="Right"></Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="FontSize" Value="22"></Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBlock" x:Key="Text1" BasedOn="{StaticResource AllTexts}">
            <Setter Property="FontSize" Value="24"></Setter>
            <Setter Property="FontWeight" Value="ExtraBlack"></Setter>
        </Style>
        <Style TargetType="TextBlock" x:Key="Text2" BasedOn="{StaticResource AllTexts}">
            <Setter Property="FontSize" Value="18"></Setter>
            <Setter Property="Foreground" Value="DarkGray"></Setter>
        </Style>

    </Window.Resources>


    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2" Style="{StaticResource Text2}" x:Name="MyTextBlock2"/>
        <TextBlock Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Style="{StaticResource Text1}" x:Name="MyTextBlock1">
          
        </TextBlock>
        <Button Grid.Row="2" Style="{StaticResource MyStyle}" Click="clear">AC</Button>
        <Button Grid.Row="3"  Style="{StaticResource Opreater}" Click="Button_Click">7</Button>
        <Button Grid.Row="4" Style="{StaticResource Opreater}" Click="Button_Click">4</Button>
        <Button Grid.Row="5" Style="{StaticResource Opreater}" Click="Button_Click">1</Button>
        <Button Grid.Row="6" Width="160" Grid.ColumnSpan="2" Style="{StaticResource Opreater}" Click="Button_Click" >0</Button>

        <Button Grid.Row="2" Grid.Column="1" Style="{StaticResource MyStyle}" Click="minus">+/-</Button>
        <Button Grid.Row="3"  Grid.Column="1" Style="{StaticResource Opreater}" Click="Button_Click">8</Button>
        <Button Grid.Row="4"  Grid.Column="1"  Style="{StaticResource Opreater}" Click="Button_Click">5</Button>
        <Button Grid.Row="5"  Grid.Column="1" Style="{StaticResource Opreater}" Click="Button_Click">2</Button>

        <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource MyStyle}" Click="percent" >%</Button>
        <Button Grid.Row="3"  Grid.Column="2"  Style="{StaticResource Opreater}" Click="Button_Click">9</Button>
        <Button Grid.Row="4"  Grid.Column="2"  Style="{StaticResource Opreater}" Click="Button_Click">6</Button>
        <Button Grid.Row="5"  Grid.Column="2"  Style="{StaticResource Opreater}" Click="Button_Click">3</Button>
        <Button Grid.Row="6"  Grid.Column="2"  Style="{StaticResource Opreater}" Click="dot">.</Button>

        <Button Grid.Row="2" Grid.Column="3"  Style="{StaticResource yellow}" Click="Button_Operater">/</Button>
        <Button Grid.Row="3"  Grid.Column="3"  Style="{StaticResource yellow}" Click="Button_Operater">*</Button>
        <Button Grid.Row="4"  Grid.Column="3"  Style="{StaticResource yellow}" Click="Button_Operater">-</Button>
        <Button Grid.Row="5"  Grid.Column="3"  Style="{StaticResource yellow}" Click="Button_Operater">+</Button>
        <Button Grid.Row="6"  Grid.Column="3"  Style="{StaticResource yellow}" Click="Button_Click_1" >=</Button>



    </Grid>
</Window>
